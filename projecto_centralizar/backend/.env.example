# Plantilla de variables de entorno para el backend.
# Copiar a .env y rellenar con valores reales (NO commitear el .env).

DATABASE_URL=postgresql+asyncpg://crm_user:CHANGE_ME@localhost:5432/crm_db
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
DEBUG=true

# Claves de firma — generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME
SESSION_SECRET_KEY=CHANGE_ME

# Opcional — duración de tokens JWT (en minutos)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_MINUTES=60

# Opcional — retención de logs en días (limpieza vía DELETE /api/logs/cleanup)
# LOG_RETENTION_DAYS=90
